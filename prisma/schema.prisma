generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                String             @id @default(cuid())
  title             String
  description       String             @default("")
  genre             String             @default("")
  targetAudience    String             @default("")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  manuscripts       Manuscript[]
  analysisRuns      AnalysisRun[]
  characterConcepts CharacterConcept[]
  storyBeats        StoryBeat[]
  timelineEvents    TimelineEvent[]
  characters        CharacterProfile[]
  eventWeights      EventWeight[]
  issues            ConsistencyIssue[]
}

model CharacterConcept {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name              String
  role              String   @default("unknown")
  status            String   @default("draft")
  tagsJson          String   @default("[]")
  logline           String   @default("")
  description       String   @default("")
  appearance        String   @default("")
  voice             String   @default("")
  goal              String   @default("")
  motivation        String   @default("")
  desire            String   @default("")
  fear              String   @default("")
  wound             String   @default("")
  secret            String   @default("")
  strength          String   @default("")
  weakness          String   @default("")
  conflict          String   @default("")
  relationshipNotes String   @default("")
  backstory         String   @default("")
  arcStart          String   @default("")
  arcTurningPoint   String   @default("")
  arcEnd            String   @default("")
  plotFunction      String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId, name])
  @@index([projectId, updatedAt])
}

model Manuscript {
  id             String        @id @default(cuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapterNumber  Int
  title          String
  body           String        @default("")
  contentHtml    String?
  contentJson    String?
  editorSettings String?
  memo           String        @default("")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  analysisRuns   AnalysisRun[]

  @@index([projectId, chapterNumber])
}

model AnalysisRun {
  id             String             @id @default(cuid())
  projectId      String
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manuscriptId   String?
  manuscript     Manuscript?        @relation(fields: [manuscriptId], references: [id], onDelete: SetNull)
  scope          String
  status         String
  summary        String             @default("")
  rawJson        String
  createdAt      DateTime           @default(now())
  storyBeats     StoryBeat[]
  timelineEvents TimelineEvent[]
  characters     CharacterProfile[]
  eventWeights   EventWeight[]
  issues         ConsistencyIssue[]

  @@index([projectId, createdAt])
  @@index([manuscriptId])
}

model StoryBeat {
  id                     String      @id @default(cuid())
  projectId              String
  project                Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysisRunId          String
  analysisRun            AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  beatOrder              Int
  title                  String
  summary                String
  involvedCharactersJson String
  conflict               String
  outcome                String
  sourceChapterTitle     String

  @@index([projectId, beatOrder])
  @@index([analysisRunId])
}

model TimelineEvent {
  id                 String      @id @default(cuid())
  projectId          String
  project            Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysisRunId      String
  analysisRun        AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  chronologicalOrder Int
  narrativeOrder     Int
  estimatedTimeLabel String
  title              String
  description        String
  charactersJson     String
  location           String
  cause              String
  effect             String
  confidence         Float

  @@index([projectId, chronologicalOrder])
  @@index([analysisRunId])
}

model CharacterProfile {
  id                     String       @id @default(cuid())
  projectId              String
  project                Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysisRunId          String?
  analysisRun            AnalysisRun? @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  name                   String
  role                   String
  desire                 String
  weakness               String
  conflict               String
  relationshipNotes      String
  arcSummary             String
  firstAppearanceChapter String
  importanceScore        Int

  @@index([projectId, name])
  @@index([analysisRunId])
}

model EventWeight {
  id             String      @id @default(cuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysisRunId  String
  analysisRun    AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  category       String
  characterCount Int
  percentage     Float
  diagnosis      String
  recommendation String

  @@index([projectId, category])
  @@index([analysisRunId])
}

model ConsistencyIssue {
  id             String      @id @default(cuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysisRunId  String
  analysisRun    AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  severity       String
  type           String
  description    String
  relatedChapter String
  suggestion     String

  @@index([projectId, severity])
  @@index([analysisRunId])
}
