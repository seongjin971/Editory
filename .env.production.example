DATABASE_URL="file:./prod.db"
SESSION_SECRET="replace-with-a-random-secret-at-least-32-characters"
TESTER_EMAIL="test@test.com"
TESTER_PASSWORD="change-this-before-sharing"
NODE_ENV="production"
PORT="3000"
NEXT_PUBLIC_BASE_PATH=""
NEXT_PUBLIC_SITE_URL="http://your-domain.example"
SESSION_COOKIE_SECURE="false"

# Story analysis provider
# Keep "mock" to avoid API cost. Use "openai" only after adding OPENAI_API_KEY.
STORY_ANALYZER_PROVIDER="mock"
STORY_ANALYZER_LLM_SCOPE="chapter"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
OPENAI_ANALYSIS_MAX_CHARS="18000"
